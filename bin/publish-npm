#!/usr/bin/env bash

set -eux

npm config set '//registry.npmjs.org/:_authToken' "$NPM_TOKEN"

cd "$(dirname "$0")/.."

# Build, generate publish metadata, validate tarball layout, and smoke-test Vitest 3.x resolution
./scripts/validate-publish-package

cd dist

VERSION="$(node -p "require('./package.json').version")"

if [[ "$VERSION" =~ -([a-zA-Z]+) ]]; then
  TAG="${BASH_REMATCH[1]}"
else
  TAG="latest"
fi

npm publish --access public --tag "$TAG"
