#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ "${SKIP_BUILD:-}" != "1" ]]; then
  npm run build
fi

node scripts/utils/make-dist-package-json.cjs > dist/package.json
if [[ -e README.md ]]; then cp README.md dist/; fi
if [[ -e LICENSE ]]; then cp LICENSE dist/; fi

node scripts/utils/validate-dist-package.cjs dist

PACK="$(cd dist && npm pack --silent)"
PACK_PATH="$(cd dist && pwd)/${PACK}"

TMP_TAR="$(mktemp -d)"
TMP_CONSUMER="$(mktemp -d)"
trap 'rm -rf "$TMP_TAR" "$TMP_CONSUMER"' EXIT
tar -xzf "$PACK_PATH" -C "$TMP_TAR"
node -e "
  const fs = require('fs');
  const pkg = require('${TMP_TAR}/package/package.json');
  for (const key of ['main', 'module', 'types']) {
    const value = pkg[key];
    if (typeof value !== 'string' || value.includes('dist/')) {
      console.error('Tarball package.json has stale entrypoint:', key, value);
      process.exit(1);
    }
    const file = value.replace(/^\\.\//, '');
    if (!fs.existsSync('${TMP_TAR}/package/' + file)) {
      console.error('Tarball missing file for', key + ':', value);
      process.exit(1);
    }
  }
  console.log('validate-publish-package: tarball metadata OK');
"

cd "$TMP_CONSUMER"
npm init -y >/dev/null 2>&1
npm install "$PACK_PATH" vitest@3.2.4 vite@6 typescript@5 >/dev/null 2>&1

cat > vitest.config.ts <<'EOF'
import { defineConfig } from 'vitest/config';
export default defineConfig({});
EOF

cat > consumer-resolve.test.ts <<'EOF'
import { describe, it, expect } from 'vitest';
import { VlmRun } from 'vlmrun';

describe('vlmrun consumer resolution', () => {
  it('loads through Vite/Vitest 3.x package entry resolution', () => {
    expect(VlmRun).toBeDefined();
    expect(typeof VlmRun).toBe('function');
  });
});
EOF

npx vitest run
echo "validate-publish-package: consumer Vitest smoke OK"
